  "mapping": {
    "create": {
      "method": "POST",
      "path": "/jobs/createTask",
      "headers": {
        "Authorization": "Bearer {{user_api_key}}",
        "Content-Type": "application/json"
      },
      "body": {
        "model": "{{model.modelKey}}",
        "input": {
          "prompt": "{{request.prompt}}",
          "sound": false,
          "duration": "{{request.params.duration}}",
          "aspect_ratio": "{{request.params.aspect_ratio}}",
          "mode": "{{request.params.mode}}",
          "multi_shots": false
        }
      }
    },
    "query": {
      "method": "GET",
      "path": "/api/v1/jobs/recordInfo",
      "headers": {
        "Authorization": "Bearer {{user_api_key}}"
      },
      "query": {
        "taskId": "{{providerMeta.task_id}}"
      },
      "response_mapping": {
        "task_id": "data.taskId",
        "status": "data.state",
        "image_url": "",
        "video_url": "data.resultJson.resultUrls.0",
        "audio_url": "",
        "error_message": "data.failMsg"
      }
    }
  },
  "completenessCheck": {
    "kind": "video",
    "items": [
      {
        "field": "prompt",
        "status": "has",
        "reasoning": "Has prompt: docs state \"Video generation prompt. Takes effect when multi_shots is false.\" It is sent from request.prompt in input.prompt."
      },
      {
        "field": "negative_prompt",
        "status": "no",
        "reasoning": "No negative prompt field appears in the Kling 3.0 OpenAPI request schema or examples. The documented input fields are prompt, image_urls, sound, duration, aspect_ratio, mode, multi_shots, multi_prompt, and kling_elements."
      },
      {
        "field": "duration",
        "status": "has",
        "reasoning": "Has duration: docs state \"Total video duration in seconds. Integer value, range: 3 to 15.\""
      },
      {
        "field": "size",
        "status": "no",
        "reasoning": "No direct size/resolution request field is documented. Resolution is derived from mode and aspect_ratio; docs say \"The resolution depends on both the `mode` and `aspect_ratio` parameters.\""
      },
      {
        "field": "aspect_ratio",
        "status": "has",
        "reasoning": "Has aspect_ratio: docs state \"Video aspect ratio. Options: 16:9, 9:16, 1:1.\""
      },
      {
        "field": "image_url",
        "status": "has",
        "reasoning": "Has image reference support as image_urls: docs state \"First and last frame image URLs\" and explain index 0 first frame and index 1 last frame."
      },
      {
        "field": "first_frame_url",
        "status": "has",
        "reasoning": "Has first frame via image_urls: docs state \"if length is 1, the array item serves as the first frame\" and in multi-shot \"only the first frame is supported.\""
      },
      {
        "field": "last_frame_url",
        "status": "has",
        "reasoning": "Has last frame via image_urls: docs state \"if length is 2, index 0 is the first frame and index 1 is the last frame.\""
      },
      {
        "field": "seed",
        "status": "no",
        "reasoning": "No seed field appears in the Kling 3.0 OpenAPI request schema or examples. The documented input properties do not include seed."
      },
      {
        "field": "cfg_scale",
        "status": "no",
        "reasoning": "No cfg_scale or guidance_scale field appears in the Kling 3.0 OpenAPI request schema or examples."
      },
      {
        "field": "enable_audio",
        "status": "has",
        "reasoning": "Has audio/sound toggle as sound: docs state \"Whether to enable sound effects. true enables sound effects, false disables them.\""
      },
      {
        "field": "fps",
        "status": "no",
        "reasoning": "No fps or framerate field appears in the Kling 3.0 OpenAPI request schema or examples."
      },
      {
        "field": "model_version",
        "status": "has",
        "reasoning": "Has mode/tier variant as mode: docs state \"Generation mode. std has standard resolution, pro has higher resolution, 4K has 4K resolution.\""
      }
    ]
